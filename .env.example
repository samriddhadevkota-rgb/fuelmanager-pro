DATABASE_URL=postgresql+asyncpg://fuel_user:fuel_pass@postgres:5432/fuel_db
DATABASE_URL_SYNC=postgresql://fuel_user:fuel_pass@postgres:5432/fuel_db

REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://fuel_user:fuel_pass@rabbitmq:5672/

JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@fuelmanager.com
EMAILS_FROM_NAME=FuelManager Pro

APP_NAME=FuelManager Pro
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
FRONTEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:8001
SECRET_KEY=change-this-secret-key-in-production

BACKEND_CORS_ORIGINS=["http://localhost:3001","http://localhost:80","http://localhost"]

NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_APP_NAME=FuelManager Pro
